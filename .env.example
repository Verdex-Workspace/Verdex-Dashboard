# ============================================================
# Verdex Dashboard — variables d'environnement (exemple)
# Copiez ce fichier en .env.local et renseignez vos secrets.
# Toute variable exposée au client DOIT être préfixée par VITE_.
# ============================================================

# Environnement logique de l'app : development | staging | production
VITE_APP_ENV=development
VITE_APP_NAME=Verdex Dashboard

# URL de l'API / BFF (laisser vide tant que le backend n'existe pas)
VITE_API_BASE_URL=

# Supabase (à brancher plus tard) — la clé anon est publique côté client
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ----- Secrets serveur (NE PAS préfixer VITE_, ne jamais committer) -----
# À définir dans .env.local ou dans le dashboard Vercel.
# SUPABASE_SERVICE_ROLE_KEY=
# GITHUB_TOKEN=                      # PAT fine-grained pour /api/github

# Cache Redis (Upstash, REST) — utilisé par les connecteurs serverless.
# Laisser vide = pas de cache (dégradation gracieuse, no-op).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
